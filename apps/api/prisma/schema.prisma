generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ConversationStatus {
  OPEN
  WAITING_HUMAN
  RESOLVED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  PDF
  DOCUMENT
  SYSTEM
}

enum LeadStatus {
  OPEN
  WON
  LOST
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum ServiceOrderStatus {
  OPEN
  QUOTED
  APPROVED
  IN_PROGRESS
  DONE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  WEBHOOK
  AI_RESPONSE
  WHATSAPP_SEND
}

model Company {
  id          String   @id @default(cuid())
  name        String
  document    String?  @unique
  slug        String   @unique
  aiPersona   String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  roles       Role[]
  clients     Client[]
  leads       Lead[]
  funnels     Funnel[]
  products    Product[]
  services    Service[]
  documents   KnowledgeDocument[]
  whatsapps   WhatsAppInstance[]
  logs        AuditLog[]
}

model User {
  id           String     @id @default(cuid())
  companyId    String
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  roleId       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role         Role?      @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  tasks        Task[]
  logs         AuditLog[]

  @@index([companyId])
}

model Role {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  permissions Json
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([companyId, name])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  phone       String
  email       String?
  document    String?
  address     String?  @db.Text
  notes       String?  @db.Text
  origin      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads       Lead[]
  conversations Conversation[]
  tasks       Task[]
  notesList   Note[]
  tags        ClientTag[]
  orders      ServiceOrder[]
  payments    Payment[]

  @@unique([companyId, phone])
  @@index([companyId, name])
}

model Tag {
  id        String   @id @default(cuid())
  companyId String
  name      String
  color     String
  createdAt DateTime @default(now())

  clients   ClientTag[]
  leads     LeadTag[]

  @@unique([companyId, name])
}

model ClientTag {
  clientId String
  tagId    String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}

model Funnel {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stages    FunnelStage[]
  leads     Lead[]

  @@unique([companyId, name])
}

model FunnelStage {
  id        String @id @default(cuid())
  funnelId  String
  name      String
  position  Int
  color     String
  funnel    Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@unique([funnelId, position])
}

model Lead {
  id          String     @id @default(cuid())
  companyId   String
  clientId    String
  funnelId    String
  stageId     String
  title       String
  valueCents  Int        @default(0)
  status      LeadStatus @default(OPEN)
  interest    String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  funnel      Funnel     @relation(fields: [funnelId], references: [id])
  stage       FunnelStage @relation(fields: [stageId], references: [id])
  tags        LeadTag[]

  @@index([companyId, status])
}

model Conversation {
  id          String             @id @default(cuid())
  companyId   String
  clientId    String
  whatsappId  String?
  status      ConversationStatus @default(OPEN)
  assignedTo  String?
  lastMessageAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([companyId, status])
}

model Message {
  id             String           @id @default(cuid())
  companyId      String
  conversationId String
  externalId      String?
  direction       MessageDirection
  type            MessageType
  body            String?          @db.Text
  mediaUrl        String?
  metadata        Json?
  createdAt       DateTime         @default(now())

  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model Task {
  id          String     @id @default(cuid())
  companyId   String
  clientId    String?
  userId      String?
  title       String
  description String?    @db.Text
  dueAt       DateTime?
  status      TaskStatus @default(OPEN)
  createdByAi Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client      Client?    @relation(fields: [clientId], references: [id])
  user        User?      @relation(fields: [userId], references: [id])

  @@index([companyId, status])
}

model Note {
  id        String   @id @default(cuid())
  companyId String
  clientId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  priceCents  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  priceCents  Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ServiceOrder {
  id          String             @id @default(cuid())
  companyId   String
  clientId    String
  title       String
  description String             @db.Text
  status      ServiceOrderStatus @default(OPEN)
  quoteCents  Int?
  approvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(cuid())
  companyId   String
  clientId    String
  amountCents Int
  status      PaymentStatus @default(PENDING)
  pixCode     String?       @db.Text
  dueAt       DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  mimeType    String
  storageKey  String?
  status      String   @default("PROCESSING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks      KnowledgeChunk[]
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  companyId   String
  documentId  String
  content     String   @db.Text
  tokenCount  Int
  qdrantPointId String @unique
  createdAt   DateTime @default(now())

  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([companyId, documentId])
}

model WhatsAppInstance {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  instanceKey String   @unique
  status      String   @default("DISCONNECTED")
  qrCode      String?  @db.Text
  webhookUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(cuid())
  companyId String
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime    @default(now())

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
}
